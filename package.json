{
  "name": "atlas-manager",
  "version": "0.1.0",
  "description": "Self-hosted management and automation platform for the Atlas homelab server.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "homelab",
    "server-management",
    "automation",
    "typescript",
    "express"
  ],
  "author": "Gustavo Pinto",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
